# Environment variables example for Ocean Enterprise marketplace application

#OE NODES
#DEFAULT OE NODE USED BY THE MARKETPLACE
NEXT_PUBLIC_PROVIDER_URL=https://<your-default-oe-node-url>
#OE NODE WHOSE METADATA CACHE IS USED BY THE MARKETPLACE TO READ ASSETS 
NEXT_PUBLIC_METADATACACHE_URI=["https://<your-oe-node-url>/"]
#LIST OF OE NODES WHOSE ASSETS WILL BE LISTED IN THE CATALOGUE AND THAT CAN BE USED TO ENCRYPT NEW ASSET DESCRIPTIONS AT PUBLISHING TIME
#NEXT_PUBLIC_NODE_URI_INDEXED=["https://ocean-node-vm7.oceanenterprise.io/", "https://ocean-node-vm7.oceanenterprise.io/"]

#BLOCKCHAIN RPC - e.g., Eth Sepolia blockchain
NEXT_PUBLIC_NODE_URI_MAP={"11155111":"https://<your-rpc-provider-url-and-key>"}

#IPFS
NEXT_PUBLIC_IPFS_GATEWAY=https://<your-ipfs-gateway>
NEXT_PUBLIC_IPFS_UPLOAD_URL=https://<your-ipfs-provider-upload-url>
NEXT_PUBLIC_IPFS_DELETE_URL=https://<your-ipfs-provider-upload-url>
IPFS_JWT=<your-ipfs-jwt>
NEXT_PUBLIC_IPFS_UNPIN_FILES=true

#CURRENCIES AND MARKET FEES
#TOKENS - e.g., EURC on Eth Sepolia
NEXT_PUBLIC_ALLOWED_ERC20_ADDRESSES={"11155111":["0x08210F9170F89Ab7658F0B5E3fF39b0E03C594D4"]}
#FIXED FEE - e.g., 1 EURC fixed fee for Eth Sepolia
#NEXT_PUBLIC_CONSUME_MARKET_ORDER_FEE_MAP={"11155111":[{"token": "0x08210F9170F89Ab7658F0B5E3fF39b0E03C594D4", "amount": "1000000"}]}
#PERCENTAGE FEE - e.g., 10% percentage fee
#NEXT_PUBLIC_CONSUME_MARKET_FEE=0.1
#WALLET WHERE FEE IS COLLECTED
#NEXT_PUBLIC_MARKET_FEE_ADDRESS=<your-marketplace-wallet-address>

#SSI - used only if SSI is enabled
#NEXT_PUBLIC_SSI_ENABLED=true
#POLICY SERVER
#NEXT_PUBLIC_SSI_POLICY_SERVER=https://<your-policy-server-url>
#DEFAULT SSI WALLET
#NEXT_PUBLIC_SSI_WALLET_API=https://<your-ssi-wallet-url>
#OPA SERVER
#NEXT_PUBLIC_OPA_SERVER_URL=http://<your-opa-server>
#DEFAULT STATIC POLICIES APPLIED TO ALL VERIFIABLE CREDENTIALS
NEXT_PUBLIC_SSI_DEFAULT_POLICIES_URL=https://raw.githubusercontent.com/OceanProtocolEnterprise/policy-server/refs/heads/main/default-verification-policies

#DATASPACE NAME USED TO FILTER ASSETS 
#NEXT_PUBLIC_DATASPACE=

#LICENCE FILE SIZE LIMIT IN KB (USED TO VALIDATE LICENSE FILES UPLOADED BY PUBLISHERS)
NEXT_PUBLIC_MAX_LICENSE_FILE_SIZE_KB=700

#MARKET-LEVEL AUTHENTICATION USING AUTHENTIK SERVER
# NEXT_PUBLIC_AUTH_ENABLED=true
# NEXT_PUBLIC_AUTH_PROVIDER=oidc
# NEXT_PUBLIC_OIDC_ISSUER=<your_oidc_issuer_url>
# NEXT_PUBLIC_OIDC_CLIENT_ID=<your_oidc_client_id>
# OIDC_CLIENT_SECRET=<your_oidc_client_secret>
# NEXT_PUBLIC_OIDC_REDIRECT_URI=<your_oidc_redirect_uri>
# NEXT_PUBLIC_OIDC_TOKEN_URL=<your_oidc_token_url>
# NEXT_PUBLIC_OIDC_SIGNUP_FLOW=<your_oidc_signup_flow> # Optional: only needed if your OIDC provider has a separate signup flow
# NEXT_PUBLIC_FEDERATED_OIDC_ISSUERS=["<federated_idp_issuer_substring>"] # Optional: JSON array of issuer substrings that require two-step federated logout
# NEXT_PUBLIC_FEDERATED_IDP_END_SESSION_URL=<federated_idp_end_session_url> # Optional: end-session URL for the federated IDP

#OTHERS
#ENCRYPT ASSET DESCRIPTION AT PUBLISHING TIME
NEXT_PUBLIC_ENCRYPT_ASSET=true
#HIDE ONBOARDING AT INITIAL ACCESS TIME 
NEXT_PUBLIC_HIDE_ONBOARDING_MODULE_BY_DEFAULT=false
#SSI WALLET UI USED IN THE ONBOARDING MODULE
#NEXT_PUBLIC_SSI_UI_URL=https://<your-wallet-ui-url>
